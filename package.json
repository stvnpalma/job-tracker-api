{
  "name": "job-tracker-api",
  "version": "1.0.0",
  "description": "A REST API to track job applications, built with Node.js, TypeScript, and AWS",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "test": "jest --forceExit --runInBand",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "preset": "ts-jest",
        "testMatch": [
          "<rootDir>/tests/unit/**/*.test.ts"
        ],
        "testEnvironment": "node",
        "transform": {
          "^.+\\.ts$": [
            "ts-jest",
            {
              "tsconfig": "./tsconfig.test.json"
            }
          ]
        }
      },
      {
        "displayName": "integration",
        "preset": "ts-jest",
        "testMatch": [
          "<rootDir>/tests/integration/**/*.test.ts"
        ],
        "testEnvironment": "node",
        "transform": {
          "^.+\\.ts$": [
            "ts-jest",
            {
              "tsconfig": "./tsconfig.test.json"
            }
          ]
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stvnpalma/job-tracker-api.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/stvnpalma/job-tracker-api/issues"
  },
  "homepage": "https://github.com/stvnpalma/job-tracker-api#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
